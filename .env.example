# My3DConverter Environment Variables
# Copy this file to .env and add your actual values

# Your fal.ai API key (REQUIRED)
FAL_API_KEY=your-fal-api-key-here

# Password to access the website (REQUIRED for security)
# Change this to your own secure password!
APP_PASSWORD=MySecret3D2025

# Server port (Railway sets this automatically)
PORT=3000
